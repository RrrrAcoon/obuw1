<Window x:Class="Obuw6.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw6"
        mc:Ignorable="d"
        FontFamily="Arial"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация" Height="400" Width="400">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock HorizontalAlignment="Center" Text="Авторизация" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Логин" Margin="0,0,0,10"/>
        <TextBox x:Name="txtLogin" Margin="0,0,0,10" Height="25"/>

        <TextBlock Text="Пароль" Margin="0,0,0,10"/>
        <TextBox x:Name="txtParol" Margin="0,0,0,10" Height="25"/>

        <Button Content="Войти" Click="Knopka1" Background="LightGreen" Height="30" Margin="0,0,0,20"/>
        <Button Content="Войти как Гость" Click="Knopka2" Background="Green" Height="30" Margin="0,0,0,20"/>

    </StackPanel>
</Window>
