<Window x:Class="Obuw6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw6.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw6"
        mc:Ignorable="d"
        FontFamily="Arial"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        Title="Каталог товаров" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="LightGreen">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Icon.png" />
            <Button Grid.Column="1" Content="Выйти" Click="Vihod" Width="100" Margin="10,10"/>
            <TextBlock Grid.Column="2" x:Name="txtPolzovatel" FontSize="16" FontWeight="bold" HorizontalAlignment="Right"/>
        </Grid>

        <ListView Grid.Row="1" Margin="10" HorizontalContentAlignment="Stretch" x:Name="LvElement">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type m:Tovar}">
                    <StackPanel Orientation="Horizontal" Margin="5" Background="{Binding CvetFona}">
                        <Image Width="100" Height="100" Source="{Binding PolniyPutKFoto}"/>

                        <StackPanel Width="600" Margin="5">
                            <TextBlock Text="{Binding Naimenovanie}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Opisanie}"/>
                            <TextBlock Text="{Binding Proizvoditel.Nazvanie}"/>
                            <TextBlock Text="{Binding Ostatok}" />
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Cena, StringFormat='{}{0:F2} руб'}" TextDecorations="Strikethrough" Visibility="{Binding VidimostStaroyCeni}" />
                            <TextBlock Text="{Binding TecuchayaCena, StringFormat='{}{0:F2} руб'}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Skidka, StringFormat='{}{0}%'}" Foreground="Red" Visibility="{Binding VidimostStaroyCeni}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
